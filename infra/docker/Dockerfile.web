FROM node:20-alpine AS builder

WORKDIR /app

# Build args para variáveis de ambiente do Vite
ARG VITE_API_URL=http://localhost:3090/api
ENV VITE_API_URL=$VITE_API_URL

# Copiar package.json da raiz
COPY package*.json ./

# Copiar shared package (dependência local)
COPY packages/shared ./packages/shared

# Copiar package.json do web
COPY apps/web/package*.json ./apps/web/

# Instalar dependências do monorepo
RUN npm install --workspace=@fusehotel/shared --workspace=@fusehotel/web

# Build do shared package primeiro
WORKDIR /app/packages/shared
RUN npm run build

# Voltar para diretório do web
WORKDIR /app/apps/web

# Copiar código fonte do web
COPY apps/web .

# Build do frontend
RUN npm run build

FROM nginx:1.25-alpine

# Copiar build do frontend
COPY --from=builder /app/apps/web/dist /usr/share/nginx/html

# Criar configuração nginx para SPA
RUN echo 'server { \
    listen 80; \
    root /usr/share/nginx/html; \
    index index.html; \
    location / { \
        try_files $uri $uri/ /index.html; \
    } \
}' > /etc/nginx/conf.d/default.conf

EXPOSE 80

CMD ["nginx", "-g", "daemon off;"]

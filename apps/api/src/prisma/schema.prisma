enum ContactMessageStatus {
  UNREAD
  READ
  REPLIED
  ARCHIVED
}

model ContactMessage {
  id        String               @id @default(uuid())
  name      String
  email     String
  phone     String?
  subject   String
  message   String               @db.Text
  status    ContactMessageStatus @default(UNREAD)

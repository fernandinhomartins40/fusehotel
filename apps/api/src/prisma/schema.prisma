generator client {
  provider = "prisma-client-js"

}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")

}

enum UserRole {
  ADMIN
  MANAGER
  CUSTOMER
}

model User {
  id             String   @id @default(uuid())
  email          String   @unique
  password       String
  name           String
  phone          String?
  cpf            String?  @unique
  whatsapp       String?  @unique
  role           UserRole @default(CUSTOMER)
  isActive       Boolean  @default(true)
  emailVerified  Boolean  @default(false)
  isProvisional  Boolean  @default(false)
  profileImage   String?
  lastLoginAt    DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  refreshTokens     RefreshToken[]
  passwordResets    PasswordReset[]
  reservations      Reservation[]
  reviews           Review[]
  auditLogs         AuditLog[]
  stayGuests        StayGuest[]

  @@index([email])
  @@index([cpf])
  @@index([whatsapp])
  @@index([role])

}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
}

model PasswordReset {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
}

enum AccommodationType {
  ROOM
  SUITE
  CHALET
  VILLA
  APARTMENT
}

model Accommodation {
  id                  String            @id @default(uuid())
  name                String
  slug                String            @unique
  type                AccommodationType
  capacity            Int
  pricePerNight       Decimal           @db.Decimal(10, 2)
  description         String            @db.Text
  shortDescription    String?
  floor               Int?
  view                String?
  area                Decimal?          @db.Decimal(10, 2)
  checkInTime         String            @default("14:00")
  checkOutTime        String            @default("12:00")
  extraBeds           Int               @default(0)
  maxExtraBeds        Int               @default(0)
  extraBedPrice       Decimal           @default(0) @db.Decimal(10, 2)
  cancellationPolicy  String?           @db.Text
  metaTitle           String?
  metaDescription     String?
  keywords            String[]
  isAvailable         Boolean           @default(true)
  isFeatured          Boolean           @default(false)
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt

  images       AccommodationImage[]
  amenities    AccommodationAmenity[]
  reservations Reservation[]
  reviews      Review[]
  roomUnits    RoomUnit[]
  ratePlans    RatePlan[]
  inventoryBlocks InventoryBlock[]
  quotes       ReservationQuote[]

  @@index([slug])
  @@index([type])
  @@index([isAvailable])
  @@index([isFeatured])
}

model AccommodationImage {
  id              String @id @default(uuid())
  accommodationId String
  url             String
  alt             String
  order           Int
  isPrimary       Boolean @default(false)

  accommodation Accommodation @relation(fields: [accommodationId], references: [id], onDelete: Cascade)

  @@index([accommodationId])
}

enum AmenityCategory {
  BEDROOM
  BATHROOM
  ENTERTAINMENT
  KITCHEN
  OUTDOOR
  ACCESSIBILITY
  GENERAL
}

model Amenity {
  id          String          @id @default(uuid())
  name        String
  icon        String
  category    AmenityCategory
  description String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  accommodations AccommodationAmenity[]

  @@index([category])
}

model AccommodationAmenity {
  accommodationId String
  amenityId       String

  accommodation Accommodation @relation(fields: [accommodationId], references: [id], onDelete: Cascade)
  amenity       Amenity       @relation(fields: [amenityId], references: [id], onDelete: Cascade)

  @@id([accommodationId, amenityId])
  @@index([accommodationId])
  @@index([amenityId])
}

enum ReservationStatus {
  PENDING
  CONFIRMED
  CHECKED_IN
  CHECKED_OUT
  CANCELLED
  COMPLETED
  NO_SHOW
}

enum PaymentStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  REFUNDED
  PARTIALLY_REFUNDED
}

enum PaymentMethod {
  CREDIT_CARD
  DEBIT_CARD
  PIX
  BANK_TRANSFER
  CASH
  VOUCHER
}

enum ReservationSource {
  WEBSITE
  PHONE
  EMAIL
  WHATSAPP
  WALK_IN
  BOOKING
  AIRBNB
  EXPEDIA
  CORPORATE
  OTHER
}

enum RoomUnitStatus {
  AVAILABLE
  OCCUPIED
  DIRTY
  CLEANING
  INSPECTED
  OUT_OF_ORDER
  OUT_OF_SERVICE
  BLOCKED
}

enum HousekeepingStatus {
  CLEAN
  DIRTY
  IN_PROGRESS
  INSPECTED
}

enum StayStatus {
  RESERVED
  IN_HOUSE
  CHECKED_OUT
  CANCELLED
  NO_SHOW
}

enum FolioEntryType {
  DAILY_RATE
  EXTRA_BED
  SERVICE_FEE
  TAX
  DISCOUNT
  PAYMENT
  REFUND
  ROOM_SERVICE
  POS
  ADJUSTMENT
}

enum FolioEntrySource {
  RESERVATION
  STAY
  POS
  MANUAL
  SYSTEM
}

enum HousekeepingTaskStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  INSPECTED
  CANCELLED
}

enum HousekeepingTaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum MaintenanceOrderStatus {
  OPEN
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum MaintenanceOrderPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum POSProductCategory {
  FOOD
  BEVERAGE
  SERVICE
  CONVENIENCE
  OTHER
}

enum POSOrderOrigin {
  ROOM_SERVICE
  FRONTDESK
  RESTAURANT
  BAR
}

enum POSOrderStatus {
  OPEN
  PREPARING
  DELIVERED
  CLOSED
  CANCELLED
}

enum POSSettlementType {
  DIRECT
  FOLIO
}

enum CashSessionStatus {
  OPEN
  CLOSED
}

enum CashMovementType {
  OPENING_FLOAT
  SALE
  REFUND
  SUPPLY
  WITHDRAWAL
  CLOSING_ADJUSTMENT
}

enum QuoteStatus {
  OPEN
  SENT
  EXPIRED
  CONVERTED
  CANCELLED
}

enum PreCheckInStatus {
  PENDING
  SUBMITTED
  APPROVED
  CHECKED_IN
  CANCELLED
}

enum FNRHStatus {
  PENDING
  READY
  SENT
  ERROR
}

enum LostFoundStatus {
  OPEN
  RETURNED
  DISCARDED
}

enum StockMovementType {
  PURCHASE_IN
  TRANSFER_IN
  TRANSFER_OUT
  CONSUMPTION
  ADJUSTMENT_IN
  ADJUSTMENT_OUT
}

enum FinancialEntryType {
  RECEIVABLE
  PAYABLE
}

enum FinancialEntryStatus {
  OPEN
  PARTIALLY_PAID
  PAID
  OVERDUE
  CANCELLED
}

enum MarkupType {
  FIXED
  PERCENT
}

enum BusinessAccountType {
  COMPANY
  OPERATOR
  AGENCY
  CORPORATE
}

enum ChannelConnectionType {
  BOOKING
  AIRBNB
  EXPEDIA
  DIRECT
  OTHER
}

model Reservation {
  id                String            @id @default(uuid())
  reservationCode   String            @unique
  accommodationId   String
  userId            String?
  businessAccountId String?
  checkInDate       DateTime
  checkOutDate      DateTime
  numberOfNights    Int
  numberOfGuests    Int
  numberOfExtraBeds Int               @default(0)
  guestName         String
  guestEmail        String?
  guestPhone        String?
  guestWhatsApp     String
  guestCpf          String?
  pricePerNight     Decimal           @db.Decimal(10, 2)
  subtotal          Decimal           @db.Decimal(10, 2)
  extraBedsCost     Decimal           @default(0) @db.Decimal(10, 2)
  serviceFee        Decimal           @default(0) @db.Decimal(10, 2)
  taxes             Decimal           @default(0) @db.Decimal(10, 2)
  discount          Decimal           @default(0) @db.Decimal(10, 2)
  totalAmount       Decimal           @db.Decimal(10, 2)
  status            ReservationStatus @default(PENDING)
  paymentStatus     PaymentStatus     @default(PENDING)
  paymentMethod     PaymentMethod?
  source            ReservationSource @default(WEBSITE)
  externalChannel   String?
  externalReservationId String?
  paymentLinkUrl    String?
  paymentLinkExpiresAt DateTime?
  specialRequests   String?           @db.Text
  cancelledAt       DateTime?
  cancellationReason String?          @db.Text
  checkedInAt       DateTime?
  checkedOutAt      DateTime?
  voucherSentAt     DateTime?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  accommodation Accommodation @relation(fields: [accommodationId], references: [id])
  businessAccount BusinessAccount? @relation(fields: [businessAccountId], references: [id], onDelete: SetNull)
  user          User?         @relation(fields: [userId], references: [id], onDelete: SetNull)
  payments      Payment[]
  review        Review?
  stay          Stay?
  housekeepingTasks HousekeepingTask[]
  preCheckIn    PreCheckIn?
  feedbacks     GuestFeedback[]

  @@index([reservationCode])
  @@index([userId])
  @@index([accommodationId])
  @@index([businessAccountId])
  @@index([status])
  @@index([checkInDate])
  @@index([checkOutDate])
  @@index([source])
}

model RoomUnit {
  id                 String             @id @default(uuid())
  accommodationId    String
  name               String
  code               String             @unique
  floor              Int?
  status             RoomUnitStatus     @default(AVAILABLE)
  housekeepingStatus HousekeepingStatus @default(CLEAN)
  isActive           Boolean            @default(true)
  notes              String?            @db.Text
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  accommodation      Accommodation      @relation(fields: [accommodationId], references: [id], onDelete: Cascade)
  stays              Stay[]
  housekeepingTasks  HousekeepingTask[]
  maintenanceOrders  MaintenanceOrder[]
  posOrders          POSOrder[]
  inventoryBlocks    InventoryBlock[]
  lostFoundItems     LostFoundItem[]

  @@index([accommodationId])
  @@index([status])
  @@index([housekeepingStatus])
  @@index([isActive])
}

model Stay {
  id                 String      @id @default(uuid())
  reservationId      String      @unique
  roomUnitId         String?
  status             StayStatus  @default(RESERVED)
  adults             Int
  children           Int         @default(0)
  notes              String?     @db.Text
  expectedCheckInAt  DateTime?
  expectedCheckOutAt DateTime?
  actualCheckInAt    DateTime?
  actualCheckOutAt   DateTime?
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt

  reservation        Reservation        @relation(fields: [reservationId], references: [id], onDelete: Cascade)
  roomUnit           RoomUnit?          @relation(fields: [roomUnitId], references: [id], onDelete: SetNull)
  guests             StayGuest[]
  folio              Folio?
  housekeepingTasks  HousekeepingTask[]
  posOrders          POSOrder[]
  lostFoundItems     LostFoundItem[]

  @@index([roomUnitId])
  @@index([status])
}

model StayGuest {
  id         String   @id @default(uuid())
  stayId      String
  userId      String?
  name        String
  email       String?
  phone       String?
  cpf         String?
  isPrimary   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  stay        Stay     @relation(fields: [stayId], references: [id], onDelete: Cascade)
  user        User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([stayId])
  @@index([userId])
}

model Folio {
  id         String       @id @default(uuid())
  stayId      String       @unique
  balance     Decimal      @default(0) @db.Decimal(10, 2)
  isClosed    Boolean      @default(false)
  openedAt    DateTime     @default(now())
  closedAt    DateTime?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  stay        Stay         @relation(fields: [stayId], references: [id], onDelete: Cascade)
  entries     FolioEntry[]
}

model FolioEntry {
  id          String           @id @default(uuid())
  folioId      String
  type         FolioEntryType
  source       FolioEntrySource
  description  String
  amount       Decimal          @db.Decimal(10, 2)
  quantity     Int              @default(1)
  referenceId  String?
  metadata     Json?
  postedAt     DateTime         @default(now())
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  folio        Folio            @relation(fields: [folioId], references: [id], onDelete: Cascade)

  @@index([folioId])
  @@index([type])
  @@index([source])
}

model HousekeepingTask {
  id            String                   @id @default(uuid())
  roomUnitId     String
  stayId         String?
  reservationId  String?
  assignedToId   String?
  status         HousekeepingTaskStatus   @default(PENDING)
  priority       HousekeepingTaskPriority @default(MEDIUM)
  title          String
  notes          String?                  @db.Text
  checklist      Json?
  scheduledFor   DateTime?
  startedAt      DateTime?
  completedAt    DateTime?
  inspectedAt    DateTime?
  createdAt      DateTime                 @default(now())
  updatedAt      DateTime                 @updatedAt

  roomUnit       RoomUnit                 @relation(fields: [roomUnitId], references: [id], onDelete: Cascade)
  stay           Stay?                    @relation(fields: [stayId], references: [id], onDelete: SetNull)
  reservation    Reservation?             @relation(fields: [reservationId], references: [id], onDelete: SetNull)
  assignedTo     HousekeepingStaff?       @relation(fields: [assignedToId], references: [id], onDelete: SetNull)

  @@index([roomUnitId])
  @@index([stayId])
  @@index([reservationId])
  @@index([assignedToId])
  @@index([status])
  @@index([priority])
}

model MaintenanceOrder {
  id           String                    @id @default(uuid())
  roomUnitId    String
  status        MaintenanceOrderStatus   @default(OPEN)
  priority      MaintenanceOrderPriority @default(MEDIUM)
  title         String
  description   String?                  @db.Text
  notes         String?                  @db.Text
  estimatedCost Decimal?                 @db.Decimal(10, 2)
  actualCost    Decimal?                 @db.Decimal(10, 2)
  blockedFrom   DateTime?
  blockedUntil  DateTime?
  openedAt      DateTime                 @default(now())
  startedAt     DateTime?
  completedAt   DateTime?
  createdAt     DateTime                 @default(now())
  updatedAt     DateTime                 @updatedAt

  roomUnit      RoomUnit                 @relation(fields: [roomUnitId], references: [id], onDelete: Cascade)

  @@index([roomUnitId])
  @@index([status])
  @@index([priority])
}

model POSProduct {
  id          String             @id @default(uuid())
  name        String
  sku         String?            @unique
  category    POSProductCategory
  price       Decimal            @db.Decimal(10, 2)
  costPrice   Decimal            @default(0) @db.Decimal(10, 2)
  stockQuantity Decimal          @default(0) @db.Decimal(10, 2)
  minStockQuantity Decimal       @default(0) @db.Decimal(10, 2)
  saleUnit    String             @default("UN")
  trackStock  Boolean            @default(false)
  isActive    Boolean            @default(true)
  description String?            @db.Text
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  items       POSOrderItem[]
  inventoryMovements InventoryMovement[]

  @@index([category])
  @@index([isActive])
}

model POSOrder {
  id          String         @id @default(uuid())
  orderNumber String         @unique
  stayId      String?
  roomUnitId  String?
  origin      POSOrderOrigin
  settlementType POSSettlementType @default(DIRECT)
  status      POSOrderStatus @default(OPEN)
  customerName String?
  tableNumber String?
  notes       String?        @db.Text
  subtotalAmount Decimal     @default(0) @db.Decimal(10, 2)
  serviceFeeAmount Decimal   @default(0) @db.Decimal(10, 2)
  discountAmount Decimal     @default(0) @db.Decimal(10, 2)
  paidAmount  Decimal        @default(0) @db.Decimal(10, 2)
  totalAmount Decimal        @default(0) @db.Decimal(10, 2)
  postedToFolioAt DateTime?
  closedAt    DateTime?
  cancelledAt DateTime?
  cancellationReason String? @db.Text
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  stay        Stay?          @relation(fields: [stayId], references: [id], onDelete: SetNull)
  roomUnit    RoomUnit?      @relation(fields: [roomUnitId], references: [id], onDelete: SetNull)
  items       POSOrderItem[]
  payments    POSPayment[]
  cashMovements CashMovement[]

  @@index([stayId])
  @@index([roomUnitId])
  @@index([origin])
  @@index([status])
  @@index([settlementType])
}

model POSOrderItem {
  id         String     @id @default(uuid())
  orderId     String
  productId   String
  productName String
  quantity    Int
  unitPrice   Decimal    @db.Decimal(10, 2)
  totalPrice  Decimal    @db.Decimal(10, 2)
  notes       String?    @db.Text
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  order       POSOrder   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product     POSProduct @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@index([orderId])
  @@index([productId])
}

model POSPayment {
  id            String        @id @default(uuid())
  orderId        String
  cashSessionId  String?
  amount         Decimal       @db.Decimal(10, 2)
  refundedAmount Decimal       @default(0) @db.Decimal(10, 2)
  method         PaymentMethod
  status         PaymentStatus @default(COMPLETED)
  transactionId  String?       @unique
  reference      String?
  gateway        String?
  gatewayResponse Json?
  notes          String?       @db.Text
  paidAt         DateTime?
  refundedAt     DateTime?
  createdByUserId String?
  createdByEmail String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  order          POSOrder      @relation(fields: [orderId], references: [id], onDelete: Cascade)
  cashSession    CashSession?  @relation(fields: [cashSessionId], references: [id], onDelete: SetNull)
  cashMovements  CashMovement[]

  @@index([orderId])
  @@index([cashSessionId])
  @@index([status])
  @@index([method])
}

model CashSession {
  id               String            @id @default(uuid())
  code             String            @unique
  status           CashSessionStatus @default(OPEN)
  openingFloat     Decimal           @default(0) @db.Decimal(10, 2)
  expectedCashAmount Decimal?        @db.Decimal(10, 2)
  countedCashAmount Decimal?         @db.Decimal(10, 2)
  differenceAmount Decimal?          @db.Decimal(10, 2)
  notes            String?           @db.Text
  openedByUserId   String?
  openedByEmail    String?
  closedByUserId   String?
  closedByEmail    String?
  openedAt         DateTime          @default(now())
  closedAt         DateTime?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  payments         POSPayment[]
  movements        CashMovement[]

  @@index([status])
  @@index([openedAt])
}

model CashMovement {
  id              String           @id @default(uuid())
  cashSessionId    String
  orderId          String?
  paymentId        String?
  type             CashMovementType
  method           PaymentMethod?
  amount           Decimal          @db.Decimal(10, 2)
  description      String
  performedByUserId String?
  performedByEmail String?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  cashSession      CashSession      @relation(fields: [cashSessionId], references: [id], onDelete: Cascade)
  order            POSOrder?        @relation(fields: [orderId], references: [id], onDelete: SetNull)
  payment          POSPayment?      @relation(fields: [paymentId], references: [id], onDelete: SetNull)

  @@index([cashSessionId])
  @@index([orderId])
  @@index([paymentId])
  @@index([type])
}

model Payment {
  id              String        @id @default(uuid())
  reservationId   String
  amount          Decimal       @db.Decimal(10, 2)
  method          PaymentMethod
  status          PaymentStatus @default(PENDING)
  transactionId   String?       @unique
  gateway         String?
  gatewayResponse Json?
  paidAt          DateTime?
  refundedAt      DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  reservation Reservation @relation(fields: [reservationId], references: [id], onDelete: Cascade)

  @@index([reservationId])
  @@index([transactionId])
}

model HousekeepingStaff {
  id          String   @id @default(uuid())
  name        String
  phone       String?
  role        String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tasks       HousekeepingTask[]

  @@index([isActive])
}

model LostFoundItem {
  id             String          @id @default(uuid())
  roomUnitId      String?
  stayId          String?
  title          String
  description    String?         @db.Text
  foundBy        String?
  storedLocation String?
  status         LostFoundStatus @default(OPEN)
  foundAt        DateTime        @default(now())
  claimedBy      String?
  claimedAt      DateTime?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  roomUnit       RoomUnit?       @relation(fields: [roomUnitId], references: [id], onDelete: SetNull)
  stay           Stay?           @relation(fields: [stayId], references: [id], onDelete: SetNull)

  @@index([roomUnitId])
  @@index([stayId])
  @@index([status])
}

model RatePlan {
  id                 String      @id @default(uuid())
  accommodationId    String
  name               String
  basePrice          Decimal     @db.Decimal(10, 2)
  markupType         MarkupType  @default(FIXED)
  markupValue        Decimal     @default(0) @db.Decimal(10, 2)
  minStay            Int         @default(1)
  maxStay            Int?
  allotment          Int?
  closedToArrival    Boolean     @default(false)
  closedToDeparture  Boolean     @default(false)
  isActive           Boolean     @default(true)
  salesChannel       String?
  startsAt           DateTime?
  endsAt             DateTime?
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt

  accommodation      Accommodation @relation(fields: [accommodationId], references: [id], onDelete: Cascade)

  @@index([accommodationId])
  @@index([isActive])
  @@index([salesChannel])
}

model InventoryBlock {
  id              String    @id @default(uuid())
  accommodationId String
  roomUnitId      String?
  title           String
  reason          String?
  startsAt        DateTime
  endsAt          DateTime
  stopSell        Boolean   @default(true)
  allotment       Int?
  salesChannel    String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  accommodation   Accommodation @relation(fields: [accommodationId], references: [id], onDelete: Cascade)
  roomUnit        RoomUnit? @relation(fields: [roomUnitId], references: [id], onDelete: SetNull)

  @@index([accommodationId])
  @@index([roomUnitId])
  @@index([startsAt])
  @@index([endsAt])
}

model ChannelConnection {
  id            String                @id @default(uuid())
  name          String
  type          ChannelConnectionType
  isActive      Boolean               @default(false)
  syncEnabled   Boolean               @default(false)
  externalCode  String?
  notes         String?               @db.Text
  lastSyncedAt  DateTime?
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt

  @@index([type])
  @@index([isActive])
}

model ReservationQuote {
  id                 String            @id @default(uuid())
  quoteCode          String            @unique
  accommodationId    String
  guestName          String
  guestEmail         String?
  guestPhone         String?
  source             ReservationSource @default(WHATSAPP)
  checkInDate        DateTime
  checkOutDate       DateTime
  numberOfGuests     Int
  numberOfExtraBeds  Int               @default(0)
  amount             Decimal           @db.Decimal(10, 2)
  status             QuoteStatus       @default(OPEN)
  paymentLinkUrl     String?
  expiresAt          DateTime?
  notes              String?           @db.Text
  convertedReservationId String?
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt

  accommodation      Accommodation     @relation(fields: [accommodationId], references: [id], onDelete: Cascade)

  @@index([accommodationId])
  @@index([status])
  @@index([source])
}

model PreCheckIn {
  id             String           @id @default(uuid())
  reservationId  String           @unique
  token          String           @unique
  status         PreCheckInStatus @default(PENDING)
  fnrhStatus     FNRHStatus       @default(PENDING)
  guestData      Json?
  documentData   Json?
  signatureData  String?
  submittedAt    DateTime?
  approvedAt     DateTime?
  checkedInAt    DateTime?
  sentToGovernmentAt DateTime?
  lastError      String?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  reservation    Reservation      @relation(fields: [reservationId], references: [id], onDelete: Cascade)
}

model InventoryMovement {
  id            String            @id @default(uuid())
  productId      String
  type           StockMovementType
  quantity       Decimal          @db.Decimal(10, 2)
  unitCost       Decimal?         @db.Decimal(10, 2)
  referenceId    String?
  notes          String?          @db.Text
  createdByUserId String?
  createdByEmail String?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  product        POSProduct       @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([type])
}

model FinancialEntry {
  id             String               @id @default(uuid())
  type           FinancialEntryType
  status         FinancialEntryStatus @default(OPEN)
  description    String
  category       String?
  amount         Decimal              @db.Decimal(10, 2)
  paidAmount     Decimal              @default(0) @db.Decimal(10, 2)
  dueDate        DateTime?
  issuedAt       DateTime             @default(now())
  paidAt         DateTime?
  customerName   String?
  supplierName   String?
  referenceType  String?
  referenceId    String?
  notes          String?              @db.Text
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt

  @@index([type])
  @@index([status])
  @@index([dueDate])
}

model BusinessAccount {
  id               String              @id @default(uuid())
  name             String
  type             BusinessAccountType
  document         String?
  email            String?
  phone            String?
  commissionRate   Decimal?            @db.Decimal(5, 2)
  markupType       MarkupType?
  markupValue      Decimal?            @db.Decimal(10, 2)
  paymentTermsDays Int?
  notes            String?             @db.Text
  isActive         Boolean             @default(true)
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt

  reservations     Reservation[]

  @@index([type])
  @@index([isActive])
}

model GuestFeedback {
  id             String   @id @default(uuid())
  reservationId  String
  rating         Int
  source         String?
  comment        String?  @db.Text
  respondedAt    DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  reservation    Reservation @relation(fields: [reservationId], references: [id], onDelete: Cascade)

  @@index([reservationId])
  @@index([rating])
}

model Review {
  id              String   @id @default(uuid())
  reservationId   String   @unique
  accommodationId String
  userId          String
  rating          Int
  title           String
  comment         String   @db.Text
  isApproved      Boolean  @default(false)
  approvedAt      DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  reservation   Reservation   @relation(fields: [reservationId], references: [id], onDelete: Cascade)
  accommodation Accommodation @relation(fields: [accommodationId], references: [id])
  user          User          @relation(fields: [userId], references: [id])

  @@index([accommodationId])
  @@index([isApproved])
}

enum PromotionType {
  PACKAGE
  DISCOUNT
  SEASONAL
  SPECIAL_OFFER
  EARLY_BIRD
  LAST_MINUTE
}

model Promotion {
  id                 String        @id @default(uuid())
  title              String
  slug               String        @unique
  shortDescription   String
  longDescription    String        @db.Text
  image              String?
  startDate          DateTime
  endDate            DateTime
  originalPrice      Decimal?      @db.Decimal(10, 2)
  discountedPrice    Decimal?      @db.Decimal(10, 2)
  discountPercent    Decimal?      @db.Decimal(5, 2)
  type               PromotionType
  isActive           Boolean       @default(true)
  isFeatured         Boolean       @default(false)
  termsAndConditions String?       @db.Text
  maxRedemptions     Int?
  currentRedemptions Int           @default(0)
  promotionCode      String?       @unique
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  features PromotionFeature[]

  @@index([slug])
  @@index([isActive])
  @@index([isFeatured])
  @@index([startDate])
  @@index([endDate])
}

model PromotionFeature {
  id          String @id @default(uuid())
  promotionId String
  feature     String
  order       Int

  promotion Promotion @relation(fields: [promotionId], references: [id], onDelete: Cascade)

  @@index([promotionId])
}

enum SettingsCategory {
  SITE_INFO
  BRANDING
  CONTENT
  SEO
  EMAIL
  PAYMENT
  BOOKING
  NOTIFICATIONS
  SOCIAL_MEDIA
  GENERAL
}

model Settings {

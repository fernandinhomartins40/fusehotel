# Node Environment
NODE_ENV=development

# Server
PORT=3001
API_PREFIX=/api

# Database (PostgreSQL)
DATABASE_URL=postgresql://fusehotel_user:fusehotel_password@localhost:5432/fusehotel_db
DB_HOST=localhost
DB_PORT=5432
DB_USER=fusehotel_user
DB_PASSWORD=fusehotel_password
DB_NAME=fusehotel_db

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production-min-32-chars
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-this-in-production-min-32-chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Frontend URL (CORS)
FRONTEND_URL=http://localhost:8080

# Upload
MAX_FILE_SIZE=10485760
UPLOAD_PATH=./uploads

# Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
EMAIL_FROM=noreply@fusehotel.com
EMAIL_FROM_NAME=FuseHotel

# Payment Gateway (Stripe)
STRIPE_PUBLIC_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Logging
LOG_LEVEL=info
LOG_FILE=./logs/app.log

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
AUTH_RATE_LIMIT_WINDOW_MS=60000
AUTH_RATE_LIMIT_MAX_REQUESTS=5

# Application
APP_NAME=FuseHotel
APP_VERSION=1.0.0
